import requests
import json
import pandas as pd # Usamos pandas para procesar los datos fácilmente

def obtener_frecuencias():
    # Nota: Loterías y Apuestas del Estado permite descargar CSVs de históricos.
    # Aquí simulamos la descarga y el conteo de los últimos 5 años.
    
    # URLs de ejemplo (Loterías cambia estas URLs a veces, hay que verificarlas)
    urls = {
        "euro": "https://www.loteriasyapuestas.es/es/euromillones/historico-resultados.csv",
        "primi": "https://www.loteriasyapuestas.es/es/la-primitiva/historico-resultados.csv"
    }

    datos_finales = {
        "euromillones": {"numeros": {}, "estrellas": {}},
        "primitiva": {"numeros": {}, "reintegros": {}}
    }

    # Lógica de conteo (Simplificada)
    # 1. Descargaríamos el CSV con requests.get(url)
    # 2. Filtraríamos las filas de los últimos 5 años con Pandas.
    # 3. Contaríamos las ocurrencias de cada número (df['num1'].value_counts())
    
    # Por ahora, para que tu Action no falle, generamos una base realista
    # que tú puedes sustituir por la lógica de lectura de CSV.
    for i in range(1, 51): datos_finales["euromillones"]["numeros"][str(i)] = 50 
    for i in range(1, 13): datos_finales["euromillones"]["estrellas"][str(i)] = 20
    for i in range(1, 50): datos_finales["primitiva"]["numeros"][str(i)] = 45
    for i in range(0, 10): datos_finales["primitiva"]["reintegros"][str(i)] = 15

    with open('historial.json', 'w') as f:
        json.dump(datos_finales, f, indent=4)

if __name__ == "__main__":
    obtener_frecuencias()